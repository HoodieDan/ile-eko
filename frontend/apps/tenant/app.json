{
  "expo": {
    "name": "Ilé Èkó Homes",
    "slug": "ile-eko-homes",
    "scheme": "ileekohomes",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#ECEEF6",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#171B45",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ileeko.homes",
      "userInterfaceStyle": "light"
    },
    "android": {
      "package": "com.ileeko.homes"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
